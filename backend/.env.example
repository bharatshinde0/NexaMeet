NODE_ENV=development
PORT=8000
CLIENT_URL=http://localhost:5173,http://localhost:5174

# Paste your existing MongoDB Atlas/database URI here.
# Keep the same database URI you already created; do not create a new database unless you want to.
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/<database-name>
MONGODB_TIMEOUT_MS=10000
MEETING_SCHEDULER_INTERVAL_MS=30000
MEETING_RETENTION_MS=86400000
MEETING_CLEANUP_INTERVAL_MS=300000

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
GOOGLE_CLIENT_ID=paste-your-google-oauth-client-id.apps.googleusercontent.com

# Optional AI meeting summaries. If this is empty, NexaMeet uses the built-in local summary fallback.
AI_SUMMARY_API_KEY=paste-your-ai-api-key-here
AI_SUMMARY_MODEL=gpt-4o-mini
AI_SUMMARY_ENDPOINT=https://api.openai.com/v1/chat/completions
